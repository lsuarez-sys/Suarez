<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Portfolio</title>

<style>
/* Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* Body */
body {
  font-family: Arial, sans-serif;
  background: #fdfefe;
  color: #333;
  line-height: 1.5;
}

/* Header */
.header {
  background: #dcedc8; /* softer green */
  padding: 15px 20px;
}

.header-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
}

.logo {
  font-weight: bold;
  color: #4e6e5d;
}

.nav a {
  margin-left: 15px;
  text-decoration: none;
  color: #4e6e5d;
  font-size: 14px;
}

.nav a:hover {
  color: #2e7d32;
}

/* Hero */
.hero {
  background: #e3f2fd; /* softer blue */
  text-align: center;
  padding: 60px 20px;
}

.hero h1 {
  font-size: 28px;
  margin-bottom: 10px;
}

.hero p {
  color: #555;
}

/* About */
.about {
  background: #fce4ec; /* soft pink */
  padding: 50px 20px;
  text-align: center;
}

.about h2 {
  margin-bottom: 10px;
}

/* Gallery */
.gallery {
  padding: 40px 20px;
  max-width: 1100px;
  margin: 0 auto;
}

.gallery h2 {
  margin-bottom: 20px;
  text-align: center;
}

/* Grid */
.grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

/* CARD STYLE */
.card {
  padding: 25px;
  border-radius: 15px;
  text-align: center;
  font-weight: bold;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-5px);
}

.card1 { background: #fff3e0; } 
.card2 { background: #e1f5fe; } 
.card3 { background: #f3e5f5; } 
.card4 { background: #e8f5e9; } 

.card p {
  font-weight: normal;
  font-size: 13px;
  margin-top: 8px;
  color: #666;
}

/* Footer */
.footer {
  background: #f8bbd0;
  text-align: center;
  padding: 20px;
  color: white;
  margin-top: 20px;
}

/* Tablet */
@media (min-width: 600px) {
  .grid {
    grid-template-columns: 1fr 1fr;
  }
}

/* Desktop */
@media (min-width: 1024px) {
  .grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
</style>
</head>

<body>

<!-- Header -->
<header class="header">
  <div class="header-container">
    <div class="logo">My Webpage</div>
    <nav class="nav">
      <a href="#">Home</a>
      <a href="#">About</a>
      <a href="#">Gallery</a>
      <a href="#">Contact</a>
    </nav>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <h1>Hola, I'm Lara</h1>
  <p>An IS student learning web development</p>
</section>

<!-- About -->
<section class="about">
  <h2>About Me</h2>
  <p>I express myself as a simple girl, a jolly and friendly person with a big heart.</p>
</section>

<!-- GALLERY -->
<section class="gallery">
  <h2>My Gallery</h2>
  <div class="grid">

    <div class="card card1">
      Capturing Moments
      <p>Scenes that inspired me with my fav people</p>
    </div>

    <div class="card card2">
      My Loving Fam
      <p>Special memories with loved ones</p>
    </div>

    <div class="card card3">
      The Scenery 
      <p>Simple moments captured</p>
    </div>

    <div class="card card4">
      My Friends
      <p>My unexpected friends</p>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <p>&copy; 2026 My Portfolio | Lara Suarez</p>
</footer>

</body>
</html>

